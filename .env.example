# Neon Postgres (create project at https://console.neon.tech)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/engram?sslmode=require

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Access key for API + MCP auth (generate with: npm run generate-key)
ENGRAM_ACCESS_KEY=

# Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Proactive Telegram messaging (get chat ID from /start command)
TELEGRAM_CHAT_ID=

# Vercel Cron secret (auto-injected by Vercel for cron jobs)
CRON_SECRET=

# Your deployed URL (set after first Vercel deploy)
APP_URL=https://engram-xxx.vercel.app

# Google Calendar (optional — enables calendar event creation via trigger phrases)
# Get credentials: https://console.cloud.google.com/apis/credentials
# Then run: source .env.local && npm run google-auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
CALENDAR_TIMEZONE=America/New_York

# Family color mapping — name:colorId pairs (comma-separated)
# Google Calendar colors: 1=lavender, 2=sage, 3=grape, 4=flamingo, 5=banana,
#   6=tangerine, 7=peacock, 8=graphite, 9=blueberry, 10=basil, 11=tomato
CALENDAR_FAMILY_COLORS=member1:6,member2:4,family:9
CALENDAR_DEFAULT_MEMBER=member1
